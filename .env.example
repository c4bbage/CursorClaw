# ── Project Directory / 项目目录 ──────────────────
# Cursor Agent works in this directory (default: current directory)
# Cursor Agent 在此目录中工作（默认：当前目录）
# CURSOR_PROJECT_DIR=/path/to/your/project

# ── Model / 模型 ─────────────────────────────────
# Model for Cursor Agent (default: your Cursor account default)
# Cursor Agent 使用的模型（默认：你的 Cursor 账号默认模型）
# Run `agent --list-models` to see available models
# 运行 `agent --list-models` 查看可用模型
# CURSOR_MODEL=opus-4.6-thinking

# ── Feishu (Lark) / 飞书 ──────────────────────────
# Create a bot at https://open.feishu.cn/app
# 在飞书开放平台创建机器人
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
# Comma-separated open_id allowlist (empty = allow all)
# 逗号分隔的 open_id 白名单（空 = 允许所有人）
FEISHU_ALLOWED_USERS=
# Comma-separated chat_id allowlist (empty = allow all)
# 逗号分隔的 chat_id 白名单（空 = 允许所有人）
FEISHU_ALLOWED_CHATS=

# ── Telegram ──────────────────────────────────────
# Get token from @BotFather
# 从 @BotFather 获取 Token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# Comma-separated numeric user ID allowlist (empty = allow all)
# 逗号分隔的用户 ID 白名单（空 = 允许所有人）
TELEGRAM_ALLOWED_USERS=
# Comma-separated numeric chat ID allowlist (empty = allow all)
# 逗号分隔的 chat_id 白名单（空 = 允许所有人）
TELEGRAM_ALLOWED_CHATS=

# ── ElevenLabs (TTS + STT, optional / 可选) ──────
# Get API key from https://elevenlabs.io
# 从 https://elevenlabs.io 获取 API Key
ELEVENLABS_API_KEY=
# Voice ID for TTS (default: JBFqnCBsd6RMkjVDRZzb)
# TTS 声音 ID（默认：JBFqnCBsd6RMkjVDRZzb）
# Browse: https://elevenlabs.io/app/voice-library
ELEVENLABS_VOICE_ID=
